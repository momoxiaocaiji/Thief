{
  "name": "thief",
  "version": "4.0.1",
  "author": "SanJin <lauixData@gamil.com>",
  "description": "一款真正的创新摸鱼神器",
  "license": "MIT",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "start": "electron .",
    "build": "vite build && electron-builder --dir --mac",
    "build:dmg": "vite build && electron-builder --mac dmg",
    "build:dir": "vite build && electron-builder --dir --mac",
    "preview": "vite preview --host 127.0.0.1 --port 4173"
  },
  "build": {
    "productName": "thief",
    "appId": "c.team.thief",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "static/**/*",
      "build/icons/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    }
  },
  "dependencies": {
    "axios": "^1.7.9",
    "element-plus": "^2.11.5",
    "hotkeys-js": "^4.0.0",
    "iconv-lite": "^0.7.0",
    "pdfjs-dist": "^4.8.69",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "sass": "^1.83.0",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
